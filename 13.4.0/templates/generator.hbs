<div class="header">
	<select id="type">
		<option hidden disabled selected value="false">{{localize 'WFRP4E.Looting.Menu.Generator.Types.Title'}}</option>
		{{#each params.types}}
		<option value="{{this.value}}" data-type="{{this.type}}">{{this.name}}</option>
		{{/each}}
	</select>
	<select id="item">
		<option hidden disabled selected value="false">{{localize 'WFRP4E.Looting.Menu.Generator.Types.Item'}}</option>
		{{#each params.items}}
		<option hidden value="{{this.uuid}}" title="{{#if this.pack}}{{this.pack}}{{else}}{{localize 'DOCUMENT.Items'}}{{/if}}" data-type="{{#if (eq this.type "weapon")}}{{this.group}}{{else}}{{this.type}}{{/if}}">{{this.name}}</option>
		{{/each}}
	</select>
</div>
<div hidden class="base_item trapping">
	<div>
		<div class="enc" style="width: 20%;">
			<span>{{localize 'Encumbrance'}}</span>
			<input id="base.encumbrance" disabled type="number">
		</div>
		<div class="money" style="width: 40%;">
			<input id="base.money.gc" class="gold" disabled type="number" data-tooltip="{{localize 'NAME.GCPlural'}}" placeholder="{{localize 'MARKET.Abbrev.GC'}}">
			<input id="base.money.ss" class="silver" disabled type="number" data-tooltip="{{localize 'NAME.SSPlural'}}" placeholder="{{localize 'MARKET.Abbrev.SS'}}">
			<input id="base.money.bp" class="brass" disabled type="number" data-tooltip="{{localize 'NAME.BPPlural'}}" placeholder="{{localize 'MARKET.Abbrev.BP'}}">
		</div>
		<div class="availability" style="width: 40%;">
			<span>{{localize 'Availability'}}</span>
			<input id="base.availability" disabled type="text">
		</div>
	</div>
	<div>
		<div class="item_type" style="width: 30%;">
			<span>{{localize 'Type'}}</span>
			<input id="base.type" disabled type="text">
		</div>
		<div class="properties" style="width: 80%;">
			<input id="base.properties" disabled type="text" data-tooltip="{{localize 'Item Properties'}}">
		</div>
	</div>
</div>
