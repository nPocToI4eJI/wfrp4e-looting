<div hidden class="presets">
	{{#each params.presets}}
	<label data-id="{{this.id}}" data-types="{{this.types}}"{{#if this.hasValue}} data-value="1"{{/if}} style="--qualities_border: var(--qualities-{{this.color}}_border); --qualities: var(--qualities-{{this.color}});" data-tooltip="
		<span style='font-style: italic;'>{{this.hint}}</span>
		<hr>
		{{#if this.value}}
		<span style='font-style: italic;'>{{localize 'WFRP4E.Looting.Menu.Generator.RatioOfProperties.Title'}}: <b>{{this.value}}</b></span>
		<hr>
		{{/if}}
		{{#if this.qualities}}
		<div class='WFRP4eLooting-tooltip'>
			<span>{{localize 'Qualities'}}: </span>
			<ul>
				{{#each this.qualities}}
				{{#if (gt this.chance 0)}}
				{{#if (gt this.quantity 0)}}
				<li class='qualities'>{{#if (gt this.quantity 1)}}{{this.quantity}}x: {{/if}}{{this.label}}{{#unless (eq this.chance 100)}} [{{this.chance}}%]{{/unless}}</li>
				{{/if}}
				{{/if}}
				{{/each}}
			</ul>
		</div>
		{{/if}}
		{{#if this.flaws}}
		<div class='WFRP4eLooting-tooltip'>
			<span>{{localize 'Flaws'}}: </span>
			<ul>
				{{#each this.flaws}}
				{{#if (gt this.chance 0)}}
				{{#if (gt this.quantity 0)}}
				<li class='flaws'>{{#if (gt this.quantity 1)}}{{this.quantity}}x: {{/if}}{{this.label}}{{#unless (eq this.chance 100)}} [{{this.chance}}%]{{/unless}}</li>
				{{/if}}
				{{/if}}
				{{/each}}
			</ul>
		</div>
		{{/if}}
	">{{#if this.hasValue}}1x {{/if}}{{this.label}}<input hidden type="checkbox" name="{{this.name}}"></label>
	{{/each}}
</div>
<div class="props"></div>
<button hidden type="button" data-action="create">{{localize 'WFRP4E.Looting.Menu.Generator.Create'}}</button>